{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm run build:*)",
      "Bash(docker restart:*)",
      "Bash(curl:*)",
      "Bash(jq:*)",
      "Bash(docker ps:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [{"type": "command", "command": "/home/hercules/v11/hooks/detect-project"}]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {"type": "command", "command": "/home/hercules/v11/hooks/guard-write-gates"},
          {"type": "command", "command": "/home/hercules/v11/hooks/guard-enforcement"}
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {"type": "command", "command": "/home/hercules/v11/hooks/guard-enforcement"},
          {"type": "command", "command": "/home/hercules/v11/hooks/enforce-test-coverage"}
        ]
      },
      {
        "matcher": "Task",
        "hooks": [{"type": "command", "command": "/home/hercules/v11/hooks/guard-effort"}]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {"type": "command", "command": "/home/hercules/v11/hooks/verify-syntax"},
          {"type": "command", "command": "/home/hercules/v11/hooks/track-autonomy"}
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [{"type": "command", "command": "/home/hercules/v11/hooks/track-autonomy"}]
      },
      {
        "matcher": "TaskCreate|TaskUpdate|TaskList",
        "hooks": [{"type": "command", "command": "/home/hercules/v11/hooks/sync-tasks"}]
      },
      {
        "matcher": "TaskList",
        "hooks": [{"type": "command", "command": "/home/hercules/v11/hooks/guard-teammate-timeout"}]
      },
      {
        "matcher": "Task",
        "hooks": [{"type": "command", "command": "/home/hercules/v11/hooks/track-agents"}]
      },
      {
        "matcher": "TeamCreate|Agent",
        "hooks": [{"type": "command", "command": "/home/hercules/v11/hooks/fix-team-model"}]
      }
    ],
    "Stop": [
      {
        "hooks": [{"type": "command", "command": "/home/hercules/v11/hooks/session-end"}]
      }
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "HERCULES_ROOT": "/home/hercules"
  }
}
