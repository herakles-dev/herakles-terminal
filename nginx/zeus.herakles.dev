server {
    listen 80;
    server_name zeus.herakles.dev;
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    server_name zeus.herakles.dev;

    ssl_certificate /etc/letsencrypt/live/herakles.dev/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/herakles.dev/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # Authelia authentication
    include /etc/nginx/snippets/herakles/authelia-location.conf;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;

    # Main application
    location / {
        include /etc/nginx/snippets/herakles/authelia-auth.conf;
        
        proxy_pass http://127.0.0.1:8096;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # Pass Authelia headers to backend
        proxy_set_header Remote-User $upstream_http_remote_user;
        proxy_set_header Remote-Email $upstream_http_remote_email;
        proxy_set_header Remote-Groups $upstream_http_remote_groups;
        proxy_set_header Remote-Name $upstream_http_remote_name;
        
        # Timeouts for long-running connections
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
    }

    # WebSocket endpoint
    location /ws {
        include /etc/nginx/snippets/herakles/authelia-auth.conf;
        
        proxy_pass http://127.0.0.1:8096;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # Pass Authelia headers
        proxy_set_header Remote-User $upstream_http_remote_user;
        proxy_set_header Remote-Email $upstream_http_remote_email;
        
        # WebSocket timeouts
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
        proxy_connect_timeout 7d;
    }

    # Health check (no auth required for internal monitoring)
    location /api/health {
        proxy_pass http://127.0.0.1:8096;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
    }

    # Metrics endpoint (no auth for Prometheus scraping)
    location /api/metrics {
        allow 127.0.0.1;
        allow 10.0.0.0/8;
        allow 172.16.0.0/12;
        allow 192.168.0.0/16;
        deny all;
        
        proxy_pass http://127.0.0.1:8096;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
    }

    # Vite HMR in development
    location /__vite_hmr {
        proxy_pass http://127.0.0.1:5173;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    # Static assets with caching
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2)$ {
        proxy_pass http://127.0.0.1:8096;
        proxy_cache_valid 200 1d;
        add_header Cache-Control "public, max-age=86400";
    }

    access_log /var/log/nginx/zeus.herakles.dev.access.log;
    error_log /var/log/nginx/zeus.herakles.dev.error.log;
}
