{
  "name": "herakles-terminal",
  "version": "2.0.0",
  "description": "Resilient, mobile-first web terminal for Claude Code power users",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "db:migrate": "node -e \"require('./dist/server/session/SessionStore.js')\" && echo 'Migrations run via SessionStore.init()'",
    "db:backup": "cp data/zeus.db data/zeus.db.backup.$(date +%s) && echo 'Backup created'"
  },
  "dependencies": {
    "@types/dompurify": "^3.0.5",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^11.6.0",
    "cors": "^2.8.5",
    "cron": "^4.4.0",
    "dompurify": "^3.3.1",
    "express": "^4.21.0",
    "express-rate-limit": "^8.2.1",
    "file-type": "^19.6.0",
    "helmet": "^8.1.0",
    "jose": "^6.1.3",
    "mermaid": "^11.12.2",
    "multer": "^2.0.2",
    "node-pty": "^1.0.0",
    "prism-react-renderer": "^2.4.1",
    "prom-client": "^15.1.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "uuid": "^10.0.0",
    "winston": "^3.19.0",
    "winston-loki": "^6.1.3",
    "ws": "^8.18.0",
    "youtube-sr": "^4.3.12",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.19.3",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.7",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "eslint": "^9.15.0",
    "jsdom": "^27.3.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "supertest": "^7.1.4",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.4.1",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
