# Zeus Terminal - Environment Configuration (Security Hardened)
# Copy this file to .env and configure for your environment

# =============================================================================
# Server Configuration
# =============================================================================
NODE_ENV=production
PORT=8096
HOST=127.0.0.1
LOG_LEVEL=info

# =============================================================================
# 🔒 SECURITY CONFIGURATION (IMPORTANT!)
# =============================================================================

# ⚠️ CRITICAL: Development Auth Bypass
# NEVER enable in production! Only for local dev WITHOUT Authelia
ALLOW_DEV_AUTH_BYPASS=false

# IP Whitelist (Recommended for production)
IP_WHITELIST_ENABLED=false
# Comma-separated list of allowed IPs
# Example: ALLOWED_IPS=98.193.93.71,203.0.113.42
ALLOWED_IPS=

# Allowed Origins (CORS)
ALLOWED_ORIGINS=https://zeus.herakles.dev

# Trusted Proxies (nginx, Cloudflare Tunnel)
TRUSTED_PROXIES=127.0.0.1,::1

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# =============================================================================
# Session Management
# =============================================================================
SESSION_SECRET=CHANGE_THIS_TO_RANDOM_STRING_IN_PRODUCTION
SESSION_TIMEOUT=86400
MAX_SESSIONS=50
MAX_CONNECTIONS_PER_SESSION=5
MAX_WINDOWS_PER_SESSION=6
DEFAULT_SESSION_TIMEOUT_HOURS=168

# =============================================================================
# Database
# =============================================================================
DB_PATH=/home/hercules/herakles-terminal/data/zeus.db

# =============================================================================
# Tmux Configuration
# =============================================================================
TMUX_SOCKET=/tmp/zeus-tmux
DEFAULT_SHELL=/bin/bash
TMUX_CONFIG=/home/hercules/herakles-terminal/config/tmux.conf

# =============================================================================
# WebSocket Configuration
# =============================================================================
WS_PATH=/ws
WS_HEARTBEAT_INTERVAL=30000
WS_HEARTBEAT_TIMEOUT=60000
WS_MAX_MESSAGE_SIZE=1048576

# =============================================================================
# Multi-Device Sync
# =============================================================================
SOFT_LOCK_MS=2000

# =============================================================================
# Backup Configuration
# =============================================================================
BACKUP_ENABLED=true
BACKUP_FREQUENCY=hourly
BACKUP_RETENTION_DAYS=7
BACKUP_PATH=/home/hercules/herakles-terminal/backups

# =============================================================================
# Observability
# =============================================================================
PROMETHEUS_ENABLED=true
LOKI_ENABLED=true
LOKI_URL=http://localhost:3100

# =============================================================================
# Audit Logging
# =============================================================================
AUDIT_LOG_PATH=./data/audit.log
AUDIT_LOG_RETENTION_DAYS=90

# =============================================================================
# Gemini AI (optional)
# =============================================================================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
